{
  "name": "imessage-sdk-monorepo",
  "author": "jmisilo",
  "private": true,
  "description": "Provider-neutral TypeScript SDK workspace for iMessage infrastructure",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmisilo/imessage-sdk.git"
  },
  "homepage": "https://github.com/jmisilo/imessage-sdk#readme",
  "bugs": {
    "url": "https://github.com/jmisilo/imessage-sdk/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "changeset": "changeset",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm lint:eslint && pnpm format:check",
    "lint:eslint": "eslint .",
    "package:check": "bash scripts/check-packages.sh",
    "release": "pnpm lint && pnpm build && pnpm typecheck && pnpm test && pnpm package:check && node scripts/publish-packages.mjs",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^20.19.43",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
