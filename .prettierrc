{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "<TYPES>",
    "",
    "<BUILTIN_MODULES>",
    "",
    "<THIRD_PARTY_MODULES>",
    "",
    "<TYPES>^(imessage-sdk|@imessage-sdk)",
    "^(imessage-sdk|@imessage-sdk)(/.*)?$",
    "",
    "<TYPES>^[.]",
    "^[.]"
  ],
  "importOrderTypeScriptVersion": "6.0.0"
}
