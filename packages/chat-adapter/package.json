{
  "name": "@imessage-sdk/chat-adapter",
  "version": "0.1.0",
  "description": "Provider-neutral iMessage adapter for Chat SDK",
  "author": "jmisilo",
  "keywords": [
    "chat-sdk",
    "chat-adapter",
    "imessage",
    "messaging",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmisilo/imessage-sdk.git",
    "directory": "packages/chat-adapter"
  },
  "homepage": "https://imessage-sdk.dev",
  "bugs": {
    "url": "https://github.com/jmisilo/imessage-sdk/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.33.0",
    "imessage-sdk": "workspace:^",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "chat": "^4.33.0"
  },
  "devDependencies": {
    "@chat-adapter/state-memory": "4.33.0",
    "@chat-adapter/tests": "4.33.0",
    "chat": "4.33.0"
  }
}
