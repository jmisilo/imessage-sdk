{
  "name": "imessage-sdk",
  "version": "0.1.0-beta.0",
  "description": "Provider-neutral TypeScript SDK for iMessage infrastructure",
  "author": "jmisilo",
  "keywords": [
    "imessage",
    "messaging",
    "sdk",
    "typescript",
    "blooio",
    "photon"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmisilo/imessage-sdk.git",
    "directory": "packages/imessage-sdk"
  },
  "homepage": "https://github.com/jmisilo/imessage-sdk/tree/main/packages/imessage-sdk#readme",
  "bugs": {
    "url": "https://github.com/jmisilo/imessage-sdk/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./providers/blooio": {
      "types": "./dist/providers/blooio.d.ts",
      "import": "./dist/providers/blooio.js",
      "default": "./dist/providers/blooio.js"
    },
    "./providers/photon": {
      "types": "./dist/providers/photon.d.ts",
      "import": "./dist/providers/photon.js",
      "default": "./dist/providers/photon.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:integration:blooio": "BLOOIO_LIVE_TEST=1 vitest run test/blooio.integration.test.ts",
    "test:integration:photon": "PHOTON_LIVE_TEST=1 vitest run test/photon.integration.test.ts",
    "test:integration:photon-stream": "PHOTON_LIVE_STREAM_TEST=1 vitest run test/photon.integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@photon-ai/advanced-imessage": "^1.0.0",
    "@spectrum-ts/core": "^9.3.1",
    "zod": "^4.4.3"
  }
}
