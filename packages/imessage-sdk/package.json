{
  "name": "imessage-sdk",
  "version": "0.1.2",
  "description": "Provider-neutral TypeScript SDK for iMessage infrastructure",
  "author": "jmisilo",
  "keywords": [
    "imessage",
    "messaging",
    "sdk",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmisilo/imessage-sdk.git",
    "directory": "packages/imessage-sdk"
  },
  "homepage": "https://imessage-sdk.dev",
  "bugs": {
    "url": "https://github.com/jmisilo/imessage-sdk/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
